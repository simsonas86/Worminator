# Twitch application credentials
TWITCH_APPID=your_twitch_app_id
TWITCH_APPSECRET=your_twitch_app_secret

# Twitch channel the bot should join
TARGET_CHANNEL=your_channel_name

# PostgreSQL connection settings
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name
DB_HOST=127.0.0.1
DB_PORT=5432

# Twitch user ID allowed to run superadmin commands
TWITCHSUPERADMINID=123456789

# OBS connection settings (Currently unused)
OBS_IP=127.0.0.1
OBS_PORT=4455
OBS_PASSWORD=your_obs_password
