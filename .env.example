# Twitch application credentials
TWITCH_APP_ID=your_twitch_app_id
TWITCH_APP_SECRET=your_twitch_app_secret
TWITCH_SUPERADMIN_ID=123456789

# Twitch channel the bot should join
TARGET_CHANNEL=your_channel_name

# PostgreSQL connection settings
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name
DB_HOST=127.0.0.1
DB_PORT=5432

# OBS connection settings (Currently unused)
OBS_IP=127.0.0.1
OBS_PORT=4455
OBS_PASSWORD=your_obs_password

# Disable the overlay websocket
OVERLAY_WS_DISABLED=false